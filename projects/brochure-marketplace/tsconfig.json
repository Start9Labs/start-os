{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "*": ["./*"],
      "@start9labs/marketplace": [
        "../../shared-libs/ts-modules/marketplace/index"
      ],
      "@start9labs/shared": [
        "../../shared-libs/ts-modules/shared/src/public-api"
      ]
    }
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.d.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
