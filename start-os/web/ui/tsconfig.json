{
  "extends": "../../../shared/web/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "*": ["./*"],
      "@start9labs/marketplace": ["../../../shared/web/marketplace/index"],
      "@start9labs/shared": ["../../../shared/web/shared/src/public-api"]
    }
  },
  "files": ["src/main.ts", "src/polyfills.ts"],
  "include": ["src/**/*.d.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
