{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "*": ["./*"],
      "@start9labs/marketplace": ["../marketplace/index"],
      "@start9labs/shared": ["../shared/src/public-api"]
    }
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.d.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
