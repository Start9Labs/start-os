{
  "name": "start-wrt",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "check": "tsc --project tsconfig.app.json --noEmit --skipLibCheck"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.5",
    "@angular/cdk": "^21.0.3",
    "@angular/common": "^21.0.5",
    "@angular/compiler": "^21.0.5",
    "@angular/core": "^21.0.5",
    "@angular/forms": "^21.0.5",
    "@angular/platform-browser": "^21.0.5",
    "@angular/router": "^21.0.5",
    "@taiga-ui/addon-charts": "4.64.0",
    "@taiga-ui/addon-mobile": "4.64.0",
    "@taiga-ui/addon-table": "4.64.0",
    "@taiga-ui/cdk": "4.64.0",
    "@taiga-ui/core": "4.64.0",
    "@taiga-ui/event-plugins": "^4.7.0",
    "@taiga-ui/experimental": "4.64.0",
    "@taiga-ui/icons": "4.64.0",
    "@taiga-ui/kit": "4.64.0",
    "@taiga-ui/layout": "4.64.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.5",
    "@types/node": "^24.10.1",
    "husky": "^4.3.8",
    "less-loader": "^12.3.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged --concurrent false && npm run check"
    }
  },
  "lint-staged": {
    "**/*.{js,ts,html,md,json}": "prettier --write",
    "*.css": "stylelint --fix"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "arrowParens": "avoid",
    "trailingComma": "all",
    "htmlWhitespaceSensitivity": "ignore",
    "tabWidth": 2,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}
