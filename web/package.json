{
  "name": "start-wrt",
  "version": "0.1.0-beta.1",
  "scripts": {
    "ng": "ng",
    "start": "npm run build-config && ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "build-config": "node build-config.js",
    "check": "tsc --project tsconfig.app.json --noEmit --skipLibCheck",
    "prepare": "cd .. && husky web/.husky",
    "analyze": "ng build --stats-json --named-chunks && npx -y @angular-experts/hawkeye dist/startwrt/stats.json"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@taiga-ui/addon-charts": "5.6.0",
    "@taiga-ui/addon-mobile": "5.6.0",
    "@taiga-ui/addon-table": "5.6.0",
    "@taiga-ui/cdk": "5.6.0",
    "@taiga-ui/core": "5.6.0",
    "@taiga-ui/dompurify": "5.0.1",
    "@taiga-ui/event-plugins": "^5.0.0",
    "@taiga-ui/icons": "5.6.0",
    "@taiga-ui/kit": "5.6.0",
    "@taiga-ui/layout": "5.6.0",
    "marked": "^17.0.1",
    "ng-qrcode": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/node": "^24.10.1",
    "husky": "^9.1.7",
    "less-loader": "^12.3.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "**/*.{js,ts,html,md,json}": "prettier --write",
    "*.css": "stylelint --fix"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "arrowParens": "avoid",
    "trailingComma": "all",
    "htmlWhitespaceSensitivity": "ignore",
    "tabWidth": 2,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}
