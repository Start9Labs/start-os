          "configurations": {
            "production": {
              "buildTarget": "brochure-marketplace:build:production"
            },
            "development": {
              "buildTarget": "brochure-marketplace:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 8200
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "brochure-marketplace:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/brochure-marketplace/src/**/*.ts",
              "projects/brochure-marketplace/src/**/*.html"
            ]
          }
        }
      }
    },
    "marketplace": {
      "projectType": "library",
      "root": "shared-libs/web/marketplace",
      "sourceRoot": "shared-libs/web/marketplace/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "shared-libs/web/marketplace/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "shared": {
      "projectType": "library",
      "root": "shared-libs/web/shared",
      "sourceRoot": "shared-libs/web/shared/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "shared-libs/web/shared/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "schematicCollections": [],
    "analytics": false
  },
  "schematics": {
    "@schematics/angular:component": {
      "displayBlock": true,
      "changeDetection": "OnPush",
      "style": "scss",
      "skipTests": true,
      "skipImport": true,
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
