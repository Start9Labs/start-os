{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ui": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/start-os/web/ui",
      "sourceRoot": "projects/start-os/web/ui/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "preserveSymlinks": true,
            "outputPath": {
              "base": "projects/start-os/web/dist/raw/ui",
              "browser": ""
            },
            "index": "projects/start-os/web/ui/src/index.html",
            "browser": "projects/start-os/web/ui/src/main.ts",
            "polyfills": ["zone.js", "projects/start-os/web/ui/src/polyfills.ts"],
            "tsConfig": "projects/start-os/web/ui/tsconfig.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "shared-libs/web/shared/assets",
                "output": "assets"
              },
              {
                "glob": "**/*.wasm",
                "input": "node_modules/@start9labs/argon2",
                "output": "assets"
              },
              {
                "glob": "**/*",
                "input": "node_modules/monaco-editor",
                "output": "assets/monaco-editor/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              },
              "projects/start-os/web/ui/src/manifest.webmanifest"
            ],
            "styles": [
              "node_modules/@taiga-ui/styles/taiga-ui-theme.less",
              "shared-libs/web/shared/styles/taiga.scss",
              "shared-libs/web/shared/styles/shared.scss",
              "projects/start-os/web/ui/src/styles.scss"
            ],
            "scripts": [],
            "loader": {
              ".md": "text"
            },
            "serviceWorker": "projects/start-os/web/ui/ngsw-config.json"
          },
          "configurations": {
            "production": {
              "serviceWorker": "projects/start-os/web/ui/ngsw-config.json",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/start-os/web/ui/src/environments/environment.ts",
                  "with": "projects/start-os/web/ui/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "extractLicenses": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "ci": {
              "progress": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ui:build:production"
            },
            "development": {
              "buildTarget": "ui:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 8100
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "ui:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/start-os/web/ui/src/**/*.ts",
              "projects/start-os/web/ui/src/**/*.html"
            ]
          }
        }
      }
    },
    "setup-wizard": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/start-os/web/setup-wizard",
      "sourceRoot": "projects/start-os/web/setup-wizard/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "projects/start-os/web/dist/raw/setup-wizard",
              "browser": ""
            },
            "index": "projects/start-os/web/setup-wizard/src/index.html",
            "browser": "projects/start-os/web/setup-wizard/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/start-os/web/setup-wizard/tsconfig.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "shared-libs/web/shared/assets",
                "output": "assets"
              },
              {
                "glob": "**/*.wasm",
                "input": "node_modules/@start9labs/argon2",
                "output": "assets"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              }
            ],
            "styles": [
              "node_modules/@taiga-ui/styles/taiga-ui-theme.less",
              "shared-libs/web/shared/styles/taiga.scss",
              "shared-libs/web/shared/styles/shared.scss",
              "projects/start-os/web/setup-wizard/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/start-os/web/setup-wizard/src/environments/environment.ts",
                  "with": "projects/start-os/web/setup-wizard/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "ci": {
              "progress": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "setup-wizard:build:production"
            },
            "development": {
              "buildTarget": "setup-wizard:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 8100
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "setup-wizard:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/start-os/web/setup-wizard/src/**/*.ts",
              "projects/start-os/web/setup-wizard/src/**/*.html"
            ]
          }
        }
      }
    },
    "start-tunnel": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/start-tunnel/web",
      "sourceRoot": "projects/start-tunnel/web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "projects/start-tunnel/web/dist/raw/start-tunnel",
              "browser": ""
            },
            "index": "projects/start-tunnel/web/src/index.html",
            "browser": "projects/start-tunnel/web/src/main.ts",
            "polyfills": [],
            "tsConfig": "projects/start-tunnel/web/tsconfig.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "shared-libs/web/shared/assets",
                "output": "assets"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              }
            ],
            "styles": [
              "node_modules/@taiga-ui/styles/taiga-ui-theme.less",
              "node_modules/@taiga-ui/styles/taiga-ui-fonts.less",
              "shared-libs/web/shared/styles/shared.scss",
              "projects/start-tunnel/web/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "ci": {
              "progress": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "start-tunnel:build:production"
            },
            "development": {
              "buildTarget": "start-tunnel:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 8100
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "start-tunnel:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/start-tunnel/web/src/**/*.ts",
              "projects/start-tunnel/web/src/**/*.html"
            ]
          }
        }
      }
    },
    "brochure-marketplace": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/brochure-marketplace",
      "sourceRoot": "projects/brochure-marketplace/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "preserveSymlinks": true,
            "outputPath": {
              "base": "projects/brochure-marketplace/dist/raw/brochure-marketplace",
              "browser": ""
            },
            "index": "projects/brochure-marketplace/src/index.html",
            "browser": "projects/brochure-marketplace/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/brochure-marketplace/tsconfig.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "shared-libs/web/shared/assets",
                "output": "assets"
              },
              {
                "glob": "**/*",
                "input": "projects/brochure-marketplace/src/assets/img",
                "output": "img"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              }
            ],
            "styles": [
              "node_modules/@taiga-ui/styles/taiga-ui-theme.less",
              "shared-libs/web/shared/styles/taiga.scss",
              "shared-libs/web/shared/styles/shared.scss",
              "projects/brochure-marketplace/src/styles.scss"
            ],
            "scripts": [],
            "loader": {
              ".md": "text"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/brochure-marketplace/src/environments/environment.ts",
                  "with": "projects/brochure-marketplace/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "ci": {
              "progress": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
