# Editor configuration, see https://editorconfig.org
# Repo-wide defaults so editors agree before the authoritative formatters run
# (Prettier for web + sdk, rustfmt for core). web/ keeps its own root=true config.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_size = 4

[*.md]
max_line_length = off
trim_trailing_whitespace = false
