#!/usr/bin/env python3
"""Bake a custom WiFi password into a StartWRT SD card image.

This modifies the image's persistent partition so the setup wizard uses
your chosen password instead of the sticker password. After flashing,
the sticker password is permanently replaced.

Requirements: Python 3 (no external packages)
No root required — operates on regular files only.

Usage: ./startwrt-bake-password <image.img>
"""

import getpass
import os
import struct
import sys

# --- Configuration ---
PASSWORD_LEN = 12
ALLOWED_CHARS = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789!@#$%^&*=+?"
SECTOR_SIZE = 512

# Raw format written to the rootfs partition after squashfs data.
# 8-byte magic header followed by null-terminated ASCII password.
BAKE_MAGIC = b"SWRTPWD\0"


# --- GPT parsing ---

GPT_HEADER_OFFSET = SECTOR_SIZE  # LBA 1
GPT_SIGNATURE = b"EFI PART"

# GPT header fields (offsets from start of header)
#   0:  8  Signature
#   8:  4  Revision
#  12:  4  Header size
#  16:  4  Header CRC32
#  20:  4  Reserved
#  24:  8  My LBA
#  32:  8  Alternate LBA
#  40:  8  First usable LBA
#  48:  8  Last usable LBA
#  56: 16  Disk GUID
#  72:  8  Partition entry start LBA
#  80:  4  Number of partition entries
#  84:  4  Size of partition entry
#  88:  4  Partition entry array CRC32

# GPT partition entry fields (offsets from start of entry)
#   0: 16  Partition type GUID
#  16: 16  Unique partition GUID
#  32:  8  First LBA
#  40:  8  Last LBA
#  48:  8  Attributes
#  56: 72  Name (UTF-16LE, null-terminated)


def parse_gpt_partitions(image_path):
    """Parse GPT partition table and return list of (name, first_lba, last_lba)."""
    with open(image_path, "rb") as f:
        # Read GPT header at LBA 1
        f.seek(GPT_HEADER_OFFSET)
        header = f.read(92)

        sig = header[0:8]
        if sig != GPT_SIGNATURE:
            raise ValueError(f"not a GPT disk image (signature: {sig!r})")

        entry_start_lba = struct.unpack_from("<Q", header, 72)[0]
        num_entries = struct.unpack_from("<I", header, 80)[0]
        entry_size = struct.unpack_from("<I", header, 84)[0]

        # Read partition entries
        f.seek(entry_start_lba * SECTOR_SIZE)
        partitions = []

        for _ in range(num_entries):
            entry = f.read(entry_size)
            if len(entry) < 56 + 72:
                break

            type_guid = entry[0:16]
            # All-zero type GUID means unused entry
            if type_guid == b"\x00" * 16:
                continue

            first_lba = struct.unpack_from("<Q", entry, 32)[0]
            last_lba = struct.unpack_from("<Q", entry, 40)[0]

            # Name is UTF-16LE, up to 72 bytes (36 UTF-16 code units)
            name_bytes = entry[56 : 56 + 72]
            name = name_bytes.decode("utf-16-le").rstrip("\x00")

            partitions.append((name, first_lba, last_lba))

    return partitions


def find_rootfs_partition(image_path):
    """Find the 'rootfs' partition and return (offset_bytes, size_bytes)."""
    partitions = parse_gpt_partitions(image_path)

    for name, first_lba, last_lba in partitions:
        if name == "rootfs":
            offset = first_lba * SECTOR_SIZE
            size = (last_lba - first_lba + 1) * SECTOR_SIZE
            return offset, size

    names = [name for name, _, _ in partitions]
    raise ValueError(
        f"no 'rootfs' partition found in image (found: {', '.join(names)})"
    )


SQUASHFS_MAGIC = 0x73717368  # "hsqs" in little-endian


def read_squashfs_size(f, rootfs_offset):
    """Read squashfs bytes_used from the superblock at rootfs_offset."""
    f.seek(rootfs_offset)
    sb = f.read(48)
    if len(sb) < 48:
        raise ValueError("rootfs partition too small for squashfs superblock")

    magic = struct.unpack_from("<I", sb, 0)[0]
    if magic != SQUASHFS_MAGIC:
        raise ValueError(f"rootfs does not contain squashfs (magic: {magic:#x})")

    bytes_used = struct.unpack_from("<Q", sb, 40)[0]
    return bytes_used


def align_up(n, alignment):
    """Round n up to the next multiple of alignment."""
    return (n + alignment - 1) & ~(alignment - 1)


# --- Password validation ---


def validate_password(password):
    """Validate password against the sticker password rules."""
    if len(password) != PASSWORD_LEN:
        return f"password must be exactly {PASSWORD_LEN} characters (got {len(password)})"

    for ch in password:
        if ch not in ALLOWED_CHARS:
            return f"invalid character '{ch}' — ambiguous characters (I, O, l, o, 0, 1) are not allowed"

    return None


def prompt_password():
    """Prompt for password with validation and confirmation."""
    while True:
        password = getpass.getpass(f"Enter WiFi password ({PASSWORD_LEN} chars): ")

        err = validate_password(password)
        if err:
            print(f"Invalid: {err}")
            continue

        confirm = getpass.getpass("Confirm password: ")
        if password != confirm:
            print("Passwords do not match.")
            continue

        return password


# --- Main ---


def main():
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print(f"Usage: {sys.argv[0]} <image.img>")
        print()
        print("Bakes a custom WiFi password into a StartWRT SD card image.")
        print("The sticker password will be permanently replaced after flashing.")
        sys.exit(0 if "--help" in sys.argv else 1)

    image_path = sys.argv[1]

    if not os.path.isfile(image_path):
        print(f"Error: '{image_path}' not found")
        sys.exit(1)

    # Find rootfs partition
    print("Reading partition table...")
    try:
        rootfs_offset, rootfs_size = find_rootfs_partition(image_path)
    except ValueError as e:
        print(f"Error: {e}")
        sys.exit(1)

    print(f"Found rootfs partition: offset={rootfs_offset} bytes, size={rootfs_size // 1048576} MB")

    # Prompt for password
    password = prompt_password()

    # Build payload: magic + password + null terminator
    payload = BAKE_MAGIC + password.encode("ascii") + b"\0"
    assert len(payload) == 8 + len(password) + 1

    with open(image_path, "r+b") as f:
        try:
            bytes_used = read_squashfs_size(f, rootfs_offset)
        except ValueError as e:
            print(f"Error: {e}")
            sys.exit(1)

        write_offset = rootfs_offset + align_up(bytes_used, 4096)
        rootfs_end = rootfs_offset + rootfs_size

        if write_offset + len(payload) > rootfs_end:
            print(
                f"Error: write offset ({write_offset}) + payload "
                f"exceeds rootfs partition end ({rootfs_end})"
            )
            sys.exit(1)

        print(
            f"Writing to image at offset {write_offset} "
            f"(squashfs bytes_used={bytes_used}, aligned to 4096)..."
        )
        f.seek(write_offset)
        f.write(payload)
        f.flush()
        os.fsync(f.fileno())

    print()
    print("========================================")
    print("   Password baked successfully!")
    print("========================================")
    print()
    print("Write this image to a microSD card and boot your router.")
    print("Connect to WiFi 'StartWRT' using your chosen password.")
    print("The sticker password will be permanently replaced after setup.")


if __name__ == "__main__":
    main()
